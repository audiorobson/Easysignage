# Copie para .env e ajuste URLs conforme seu Postgres/Redis/MinIO (ou S3) — instalados localmente ou em serviço remoto.
# Este projeto não inclui docker-compose; cada desenvolvedor aponta para os serviços que usar.

# API
DATABASE_URL=postgresql://easysignage:easysignage_dev@localhost:5432/easysignage
PORT=3001
JWT_SECRET=troque-por-uma-string-longa-aleatoria-em-producao
CMS_ORIGIN=http://localhost:3000
# Origens permitidas no browser (CMS + web player Vite). Sobrescreve CMS_ORIGIN quando definido.
# Inclua 127.0.0.1 se abrir o CMS por http://127.0.0.1:3000 (é outra origem em relação a localhost).
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3010,http://127.0.0.1:3010

# CMS (Next.js) — URL da API para o browser
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# Web player (Vite) — opcional
# VITE_API_URL=http://localhost:3001/api/v1

# Redis (futuro: filas, cache, pub/sub)
REDIS_URL=redis://localhost:6379

# Storage S3-compatible (MinIO local)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=easysignage
S3_SECRET_KEY=easysignage_dev_minio
S3_BUCKET=easysignage-media

# Realtime gateway
RT_PORT=3020
API_URL=http://localhost:3001/api/v1
RT_INTERNAL_SECRET=dev-rt-secret-change-in-prod
RT_WALL_TICK_MS=1000

# API → gateway (push wall.sync)
RT_GATEWAY_URL=http://localhost:3020

# Browser WebSocket URLs
NEXT_PUBLIC_RT_URL=ws://localhost:3020
# VITE_RT_URL=ws://localhost:3020
