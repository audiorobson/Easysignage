<?xml version="1.0" encoding="utf-8"?>
<!--
  SurfaceView (RTSP nativo) fica por trás da WebView — esta última fica com fundo transparente
  quando um stream RTSP está ativo (ver MainActivity.kt). A ordem dos filhos define o z-order.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <SurfaceView
        android:id="@+id/surface_rtsp"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <WebView
        android:id="@+id/webview"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</FrameLayout>
