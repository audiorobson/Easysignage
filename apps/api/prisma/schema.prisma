generator client {
  provider = "prisma-client-js"
  /** Fora do store pnpm (evita EPERM ao renomear query_engine no Windows). */
  output   = "../src/generated/prisma-client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  status    String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users   User[]
  roles   Role[]
  sites   Site[]
  devices Device[]
  assets    Asset[]
  playlists Playlist[]
  publications Publication[]
  deviceGroups DeviceGroup[]
  scheduleRules ScheduleRule[]
  deviceTelemetryEvents DeviceTelemetryEvent[]
  deviceCommands        DeviceCommand[]
  layoutTemplates       LayoutTemplate[]
  deviceLayouts         DeviceLayout[]
  videoWalls            VideoWall[]

  @@map("tenants")
}

model Asset {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  name       String
  /** image | video | audio | pdf | html | text | url (referência externa) */
  kind       String
  mimeType   String   @map("mime_type")
  /** Ficheiro em disco; nulo quando só `remoteUrl` */
  storageKey String?  @map("storage_key")
  /** HTTPS para kind=url ou referência sem ficheiro local */
  remoteUrl  String?  @map("remote_url")
  /** Miniatura (ex.: JPEG gerado no upload de imagens) */
  thumbnailKey String? @map("thumbnail_key")
  fileSize   BigInt   @map("file_size")
  status     String   @default("ready")
  createdAt  DateTime @default(now()) @map("created_at")

  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  playlistItems PlaylistItem[]
  siteCovers    Site[]    @relation("SiteCoverAsset")

  @@index([tenantId, createdAt])
  @@index([tenantId, kind])
  @@map("assets")
}

model Playlist {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  name        String
  description String?
  status      String   @default("draft")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items  PlaylistItem[]
  scheduleRules ScheduleRule[]
  videoWalls VideoWall[]

  @@index([tenantId, createdAt])
  @@map("playlists")
}

model PlaylistItem {
  id          String   @id @default(uuid()) @db.Uuid
  playlistId  String   @map("playlist_id") @db.Uuid
  assetId     String   @map("asset_id") @db.Uuid
  position    Int
  durationSec Int?     @map("duration_sec")
  createdAt   DateTime @default(now()) @map("created_at")

  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  asset    Asset    @relation(fields: [assetId], references: [id], onDelete: Restrict)

  @@unique([playlistId, position])
  @@index([playlistId])
  @@map("playlist_items")
}

/** Snapshot versionado de conteúdo atribuído ao device (Fase 3 — base). */
model Publication {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  deviceId    String   @map("device_id") @db.Uuid
  version     Int
  label       String?
  payloadJson Json     @map("payload_json")
  createdAt   DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  currentForDeviceState DeviceState? @relation("PublicationAsDeviceCurrent")

  @@unique([deviceId, version])
  @@index([tenantId])
  @@index([deviceId, createdAt(sort: Desc)])
  @@map("publications")
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  name         String
  email        String
  passwordHash String   @map("password_hash")
  status       String
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles UserRole[]

  @@unique([tenantId, email])
  @@map("users")
}

model Role {
  id              String @id @default(uuid()) @db.Uuid
  tenantId        String @map("tenant_id") @db.Uuid
  name            String
  permissionsJson Json   @map("permissions_json")

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles UserRole[]

  @@unique([tenantId, name])
  @@map("roles")
}

model UserRole {
  userId String @map("user_id") @db.Uuid
  roleId String @map("role_id") @db.Uuid

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model Site {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  name         String
  code         String?
  timezone     String   @default("America/Sao_Paulo")
  addressJson  Json?    @map("address_json")
  coverAssetId String?  @map("cover_asset_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  coverAsset Asset?   @relation("SiteCoverAsset", fields: [coverAssetId], references: [id], onDelete: SetNull)
  devices    Device[]
  videoWalls VideoWall[]

  @@index([tenantId, createdAt])
  @@map("sites")
}

model Device {
  id               String    @id @default(uuid()) @db.Uuid
  tenantId         String    @map("tenant_id") @db.Uuid
  siteId           String    @map("site_id") @db.Uuid
  name             String
  serialNumber     String?   @map("serial_number")
  platform         String    @default("unknown")
  runtimeVersion   String?   @map("runtime_version")
  status           String
  authTokenHash    String?   @map("auth_token_hash")
  pairingCode      String?   @unique @map("pairing_code")
  pairingExpiresAt DateTime? @map("pairing_expires_at")
  /** MAC para Wake-on-LAN (mesma LAN que o servidor que envia o magic packet). */
  wakeMac          String?   @map("wake_mac")
  /** Largura lógica do canvas de desenho (px). */
  viewportWidth    Int       @default(1920) @map("viewport_width")
  /** Altura lógica do canvas de desenho (px). */
  viewportHeight   Int       @default(1080) @map("viewport_height")
  /** landscape | portrait | landscape_flipped | portrait_flipped */
  displayOrientation String  @default("landscape") @map("display_orientation")
  lastSeenAt       DateTime? @map("last_seen_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  tenant Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  site   Site        @relation(fields: [siteId], references: [id], onDelete: Restrict)
  state      DeviceState?
  heartbeats Heartbeat[]
  publications Publication[]
  groupMembers DeviceGroupMember[]
  scheduleRules ScheduleRule[]
  telemetryEvents DeviceTelemetryEvent[]
  commands        DeviceCommand[]
  deviceLayout    DeviceLayout?
  videoWallTile   VideoWallTile?

  @@index([tenantId, lastSeenAt])
  @@map("devices")
}

/** Catálogo de templates de layout (sistema + custom por tenant). */
model LayoutTemplate {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String?  @map("tenant_id") @db.Uuid
  slug        String   @unique
  name        String
  description String?
  zonesJson   Json     @map("zones_json")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant        Tenant?        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  deviceLayouts DeviceLayout[]

  @@index([tenantId, sortOrder])
  @@map("layout_templates")
}

/** Layout ativo num dispositivo (bindings por zona). */
model DeviceLayout {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  deviceId   String   @unique @map("device_id") @db.Uuid
  templateId String   @map("template_id") @db.Uuid
  name       String?
  zonesJson  Json     @map("zones_json")
  revision   String
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  device   Device         @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  template LayoutTemplate @relation(fields: [templateId], references: [id], onDelete: Restrict)
  scheduleRules ScheduleRule[]

  @@index([tenantId])
  @@map("device_layouts")
}

/** Video wall — grelha de devices com canvas virtual partido em tiles. */
model VideoWall {
  id                 String   @id @default(uuid()) @db.Uuid
  tenantId           String   @map("tenant_id") @db.Uuid
  siteId             String   @map("site_id") @db.Uuid
  name               String
  gridRows           Int      @map("grid_rows")
  gridCols           Int      @map("grid_cols")
  virtualWidth       Int      @map("virtual_width")
  virtualHeight      Int      @map("virtual_height")
  displayOrientation String   @default("landscape") @map("display_orientation")
  /** draft | active | paused */
  status             String   @default("draft")
  playlistId         String?  @map("playlist_id") @db.Uuid
  syncEpochMs        BigInt?  @map("sync_epoch_ms")
  syncToleranceMs    Int      @default(80) @map("sync_tolerance_ms")
  revision           String
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  tenant Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  site   Site            @relation(fields: [siteId], references: [id], onDelete: Restrict)
  playlist Playlist?     @relation(fields: [playlistId], references: [id], onDelete: SetNull)
  tiles  VideoWallTile[]
  scheduleRules ScheduleRule[]

  @@index([tenantId, createdAt])
  @@index([siteId])
  @@map("video_walls")
}

/** Mapeamento device → posição na grelha da parede. */
model VideoWallTile {
  id        String   @id @default(uuid()) @db.Uuid
  wallId    String   @map("wall_id") @db.Uuid
  deviceId  String   @unique @map("device_id") @db.Uuid
  row       Int
  col       Int
  createdAt DateTime @default(now()) @map("created_at")

  wall   VideoWall @relation(fields: [wallId], references: [id], onDelete: Cascade)
  device Device    @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@unique([wallId, row, col])
  @@index([wallId])
  @@map("video_wall_tiles")
}

model DeviceGroup {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant  Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  members DeviceGroupMember[]
  scheduleRules ScheduleRule[]

  @@index([tenantId, createdAt])
  @@map("device_groups")
}

model DeviceGroupMember {
  groupId   String   @map("group_id") @db.Uuid
  deviceId  String   @map("device_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  group  DeviceGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  device Device      @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@id([groupId, deviceId])
  @@index([deviceId])
  @@map("device_group_members")
}

model DeviceState {
  deviceId             String   @id @map("device_id") @db.Uuid
  tenantId             String   @map("tenant_id") @db.Uuid
  currentPublicationId String?    @unique @map("current_publication_id") @db.Uuid
  currentItemJson      Json?    @map("current_item_json")
  lastSyncAt           DateTime?  @map("last_sync_at")
  storageFreeMb        Int?     @map("storage_free_mb")
  cpuPercent           Decimal? @map("cpu_percent") @db.Decimal(5, 2)
  memoryPercent        Decimal? @map("memory_percent") @db.Decimal(5, 2)
  networkStatus        String?    @map("network_status")
  /** Último snapshot agregado enviado pelo player (playback, rede, uptime, etc.) */
  telemetrySnapshotJson Json?     @map("telemetry_snapshot_json")
  telemetryUpdatedAt     DateTime?  @map("telemetry_updated_at")
  /** Última captura JPEG enviada pelo player (caminho relativo ao storage). */
  previewSnapshotKey    String?    @map("preview_snapshot_key")
  previewSnapshotAt     DateTime?  @map("preview_snapshot_at")
  /** Conteúdo a restaurar quando a janela de agenda termina. */
  scheduleBaselineItemJson Json?   @map("schedule_baseline_item_json")
  activeScheduleRuleId  String?    @map("active_schedule_rule_id") @db.Uuid
  /** Versão de publicação que o player confirmou ter aplicado (ack). */
  appliedPublicationVersion Int?   @map("applied_publication_version")
  /** Revisão de conteúdo (`contentRevision`) confirmada pelo player. */
  appliedContentRevision String?    @map("applied_content_revision")
  appliedAt            DateTime?  @map("applied_at")
  updatedAt            DateTime   @updatedAt @map("updated_at")

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  currentPublication Publication? @relation("PublicationAsDeviceCurrent", fields: [currentPublicationId], references: [id], onDelete: SetNull)

  @@map("device_state")
}

model Heartbeat {
  id          BigInt   @id @default(autoincrement())
  tenantId    String   @map("tenant_id") @db.Uuid
  deviceId    String   @map("device_id") @db.Uuid
  receivedAt  DateTime @default(now()) @map("received_at")
  isOnline    Boolean  @default(true) @map("is_online")
  appVersion  String?  @map("app_version")
  osVersion   String?  @map("os_version")
  metricsJson Json?    @map("metrics_json")

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId, receivedAt(sort: Desc)])
  @@map("heartbeats")
}

/**
 * Evento pontual de telemetria (erros de rede, falhas de porta, reconexões, etc.).
 * Categorias extensíveis: network, playback, connectivity, port, system, storage, analytics, …
 */
model DeviceTelemetryEvent {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  deviceId    String   @map("device_id") @db.Uuid
  category    String
  severity    String
  code        String?
  message     String?
  payloadJson Json?    @map("payload_json")
  createdAt   DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([tenantId, deviceId, createdAt(sort: Desc)])
  @@index([tenantId, createdAt(sort: Desc)])
  @@map("device_telemetry_events")
}

/**
 * Fila servidor → player (wake-on-LAN, GPIO, serial, HTTP de automação, …).
 * O player fará polling ou canal futuro (WebSocket) para recolher comandos pendentes.
 */
model DeviceCommand {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  deviceId    String    @map("device_id") @db.Uuid
  channel     String
  status      String    @default("pending")
  payloadJson Json      @map("payload_json")
  resultJson  Json?     @map("result_json")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  processedAt DateTime? @map("processed_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([tenantId, deviceId, status])
  @@index([tenantId, status, createdAt])
  @@map("device_commands")
}

/**
 * Regra de agendamento: playlist num dia da semana (e faixa horária) para um device ou grupo.
 * `dayOfWeek`: 1 = segunda … 7 = domingo (ISO).
 * `startMin` / `endMin`: minutos desde 00:00; fim exclusivo (ex.: dia inteiro 0–1440).
 */
model ScheduleRule {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  name        String?
  playlistId  String?  @map("playlist_id") @db.Uuid
  layoutId    String?  @map("layout_id") @db.Uuid
  videoWallId String?  @map("video_wall_id") @db.Uuid
  /// "device" | "group"
  scope       String
  deviceId    String?  @map("device_id") @db.Uuid
  groupId     String?  @map("group_id") @db.Uuid
  dayOfWeek   Int      @map("day_of_week")
  startMin    Int      @map("start_min")
  endMin      Int      @map("end_min")
  priority    Int      @default(0)
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  playlist  Playlist?     @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  layout    DeviceLayout? @relation(fields: [layoutId], references: [id], onDelete: Cascade)
  videoWall VideoWall?    @relation(fields: [videoWallId], references: [id], onDelete: Cascade)
  device    Device?       @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  group     DeviceGroup?  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([tenantId, enabled])
  @@index([tenantId, deviceId, dayOfWeek])
  @@index([tenantId, groupId, dayOfWeek])
  @@map("schedule_rules")
}
