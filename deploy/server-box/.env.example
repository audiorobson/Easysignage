# Copie para .env e ajuste antes de `docker compose up`

JWT_SECRET=altere-esta-chave-com-32-caracteres-minimo
RT_INTERNAL_SECRET=altere-o-segredo-do-realtime-gateway
POSTGRES_USER=easysignage
POSTGRES_PASSWORD=altere-a-senha-da-base-de-dados
POSTGRES_DB=easysignage

# URL da API vista pelo browser (IP ou hostname do mini PC na LAN)
NEXT_PUBLIC_API_URL=http://192.168.1.100:3001/api/v1
CORS_ORIGINS=http://192.168.1.100:3000,http://localhost:3000
CMS_ORIGIN=http://192.168.1.100:3000

# Imagens pré-build GHCR (opcional — omita para build local)
# EASYSIGNAGE_VERSION=1.0.0
# EASYSIGNAGE_API_IMAGE=ghcr.io/audiorobson/easysignage-api:1.0.0
# EASYSIGNAGE_CMS_IMAGE=ghcr.io/audiorobson/easysignage-cms:1.0.0
# EASYSIGNAGE_RT_IMAGE=ghcr.io/audiorobson/easysignage-realtime-gateway:1.0.0

# Licença: serial em config/license.key ou variável abaixo
# EASYSIGNAGE_LICENSE_KEY=

# Chave pública de PRODUÇÃO (obrigatória em ambiente comercial):
# copie deploy/keys/production-public.pem.example → config/license-public.pem
# e substitua pelo PEM real do fornecedor.
