# Copie para .env e ajuste antes de `docker compose up`

JWT_SECRET=altere-esta-chave-com-32-caracteres-minimo
POSTGRES_USER=easysignage
POSTGRES_PASSWORD=altere-a-senha-da-base-de-dados
POSTGRES_DB=easysignage

# URL da API vista pelo browser (IP ou hostname do mini PC na LAN)
NEXT_PUBLIC_API_URL=http://192.168.1.100:3001/api/v1
CORS_ORIGINS=http://192.168.1.100:3000,http://localhost:3000
CMS_ORIGIN=http://192.168.1.100:3000

# Opcional: serial já activado (ou use config/license.key)
# EASYSIGNAGE_LICENSE_KEY=
